# ============================================================
#  VARIABLES D'ENVIRONNEMENT — calepinage-api
#  Copier ce fichier en .env et remplir les valeurs
#  NE JAMAIS committer le .env sur GitHub !
# ============================================================

# Visual Crossing API
VISUALCROSSING_API_KEY=ta_cle_ici

# URL du front (pour CORS)
FRONT_URL=https://calepinage-pro.onrender.com

# Web Push (générer avec: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=ta_cle_publique_vapid
VAPID_PRIVATE_KEY=ta_cle_privee_vapid
VAPID_EMAIL=mailto:ton@email.com

# Port (Render le définit automatiquement)
PORT=3000
